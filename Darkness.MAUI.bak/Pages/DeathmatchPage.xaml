<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             x:Class="Darkness.MAUI.Pages.DeathmatchPage"
             x:DataType="vm:DeathmatchViewModel"
             Title="Deathmatch Mode">

    <Grid RowDefinitions="*, Auto" Padding="20">
        <ListView Grid.Row="0" 
                  ItemsSource="{Binding Encounters}" 
                  SelectedItem="{Binding SelectedEncounter}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Name}" 
                             Detail="{Binding RequiredLevel, StringFormat='Required Level: {0}'}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <VerticalStackLayout Grid.Row="1" Spacing="10" Padding="0,20,0,0">
            <Label Text="{Binding SelectedEncounter.Name}" 
                   FontSize="Large" 
                   FontAttributes="Bold" />
            <Label Text="{Binding SelectedEncounter.RequiredLevel, StringFormat='Required Level: {0}'}" />
            
            <Button Text="Start Battle" 
                    Command="{Binding StartDeathmatchCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
