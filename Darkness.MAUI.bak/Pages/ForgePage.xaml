<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             x:Class="Darkness.MAUI.Pages.ForgePage"
             x:DataType="vm:ForgeViewModel"
             Title="The Forge">
    <Grid RowDefinitions="*, 2*" ColumnDefinitions="*">
        <ListView Grid.Row="0" ItemsSource="{Binding Recipes}" SelectedItem="{Binding SelectedRecipe}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Name}" Detail="{Binding Result.Description}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="10">
            <Label Text="{Binding SelectedRecipe.Name}" FontSize="Large" />
            <Label Text="{Binding SelectedRecipe.Result.Description}" />
            <Label Text="Materials Required:" FontAttributes="Bold" />
            <Label Text="{Binding SelectedRecipe.Result.Type, StringFormat='Type: {0}'}" />
            <Label Text="{Binding SelectedRecipe.Result.AttackBonus, StringFormat='Attack Bonus: {0}'}" />
            <Button Text="Forge Item" Command="{Binding CraftCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
