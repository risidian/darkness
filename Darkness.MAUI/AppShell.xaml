<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Darkness.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Darkness.MAUI"
    xmlns:pages="clr-namespace:Darkness.MAUI.Pages"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate pages:LoadUserPage}"
        Route="LoadUserPage" />

    <ShellContent
        Title="Create Account"
        ContentTemplate="{DataTemplate pages:CreateUserPage}"
        Route="CreateUserPage" />

    <ShellContent
        Title="Character Creation"
        ContentTemplate="{DataTemplate pages:CharacterGenPage}"
        Route="CharacterGenPage" />

    <ShellContent
        Title="World"
        ContentTemplate="{DataTemplate pages:GamePage}"
        Route="GamePage" />

    <ShellContent
        Title="Battle"
        ContentTemplate="{DataTemplate pages:BattlePage}"
        Route="BattlePage" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Characters"
        ContentTemplate="{DataTemplate pages:CharactersPage}"
        Route="CharactersPage" />

    <ShellContent
        Title="Study"
        ContentTemplate="{DataTemplate pages:StudyPage}"
        Route="StudyPage" />

</Shell>
