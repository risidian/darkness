<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Darkness.MAUI.Pages.CharacterGenPage"
             Title="Character Creation"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
            <Label Text="Generate Your Hero"
                   FontSize="32"
                   TextColor="White"
                   HorizontalOptions="Center"
                   FontAttributes="Bold" />

            <Entry x:Name="CharacterNameEntry"
                   Placeholder="Character Name"
                   PlaceholderColor="Gray"
                   TextColor="White"
                   BackgroundColor="#1E1E1E" />

            <Label Text="Class" TextColor="White" />
            <Picker x:Name="ClassPicker"
                    Title="Select Class"
                    TextColor="White"
                    BackgroundColor="#1E1E1E">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Warrior</x:String>
                        <x:String>Mage</x:String>
                        <x:String>Rogue</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label Text="Hair Color" TextColor="White" />
            <Picker x:Name="HairColorPicker"
                    Title="Select Hair Color"
                    TextColor="White"
                    BackgroundColor="#1E1E1E">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Black</x:String>
                        <x:String>Blonde</x:String>
                        <x:String>Brown</x:String>
                        <x:String>Red</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label Text="Skin Color" TextColor="White" />
            <Picker x:Name="SkinColorPicker"
                    Title="Select Skin Color"
                    TextColor="White"
                    BackgroundColor="#1E1E1E">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Light</x:String>
                        <x:String>Medium</x:String>
                        <x:String>Dark</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Button Text="Create Character"
                    Clicked="OnCreateCharacterClicked"
                    BackgroundColor="#B71C1C"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
