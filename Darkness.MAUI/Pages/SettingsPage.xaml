<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             x:Class="Darkness.MAUI.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Audio Settings" FontSize="24" FontAttributes="Bold" />
            
            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding MasterVolume, StringFormat='Master Volume: {0:P0}'}" />
                <Slider Minimum="0" Maximum="1" Value="{Binding MasterVolume}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding MusicVolume, StringFormat='Music Volume: {0:P0}'}" />
                <Slider Minimum="0" Maximum="1" Value="{Binding MusicVolume}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding SfxVolume, StringFormat='SFX Volume: {0:P0}'}" />
                <Slider Minimum="0" Maximum="1" Value="{Binding SfxVolume}" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="Gray" HorizontalOptions="Fill" />

            <Button Text="Graphics Settings" Command="{Binding GraphicsSettingsCommand}" />
            <Button Text="Keybindings" Command="{Binding KeybindingsCommand}" />

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Save" Command="{Binding SaveCommand}" BackgroundColor="Green" WidthRequest="100" />
                <Button Text="Cancel" Command="{Binding CancelCommand}" BackgroundColor="Red" WidthRequest="100" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
