<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             xmlns:controls="clr-namespace:Darkness.MAUI.Controls"
             x:Class="Darkness.MAUI.Pages.BattlePage"
             x:DataType="vm:BattlePageViewModel"
             Title="The Forest Path - Ambush"
             BackgroundColor="Black">

    <Grid RowDefinitions="*, Auto">
        <controls:MonoGameHost Grid.Row="0" Game="{Binding GameInstance}" />

        <!-- UI Overlay for controls or status -->
        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="10">
            <Label Text="{Binding StatusText}"
                   TextColor="{Binding StatusColor}"
                   HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                <Button Text="Flee"
                        WidthRequest="120"
                        BackgroundColor="#222"
                        TextColor="White"
                        Command="{Binding FleeCommand}" />
                <Button Text="Continue"
                        WidthRequest="120"
                        BackgroundColor="#442222"
                        TextColor="White"
                        IsVisible="{Binding IsContinueVisible}"
                        Command="{Binding ContinueCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
