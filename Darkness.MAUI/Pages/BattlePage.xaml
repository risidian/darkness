<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Darkness.MAUI.Pages.BattlePage"
             Title="The Forest Path - Ambush"
             BackgroundColor="Black">

    <Grid RowDefinitions="*, Auto">
        <!-- MonoGame Battle Viewport Placeholder -->
        <Border Grid.Row="0" 
                Margin="20" 
                StrokeThickness="2" 
                Stroke="#333" 
                BackgroundColor="#111">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="[ BATTLE VIEWPORT ]" 
                       TextColor="DarkRed" 
                       FontSize="24"
                       HorizontalOptions="Center" />
                <Label Text="Undead Dogs approach from the shadows..." 
                       TextColor="Gray" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <!-- UI Overlay for controls or status (if not handled entirely in MonoGame) -->
        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="10">
            <Label x:Name="StatusLabel" 
                   Text="Battle in progress..." 
                   TextColor="White" 
                   HorizontalOptions="Center" />
            
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                <Button Text="Flee" 
                        WidthRequest="120"
                        BackgroundColor="#222"
                        TextColor="White"
                        Clicked="OnFleeClicked" />
                <Button x:Name="ContinueButton"
                        Text="Continue" 
                        WidthRequest="120"
                        BackgroundColor="#442222"
                        TextColor="White"
                        IsVisible="False"
                        Clicked="OnContinueClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
