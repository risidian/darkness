<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             x:Class="Darkness.MAUI.Pages.StudyPage"
             x:DataType="vm:StudyViewModel"
             Title="Study">
    <VerticalStackLayout Spacing="10" Padding="20">
        <Label Text="{Binding Character.Name}" FontSize="Large" />
        <Label Text="{Binding Character.AttributePoints, StringFormat='Attribute Points: {0}'}" />
        
        <Grid ColumnDefinitions="*, Auto, Auto">
            <Label Grid.Column="0" Text="{Binding Character.Strength, StringFormat='Strength: {0}'}" />
            <Button Grid.Column="1" Text="+" Command="{Binding UpgradeAttributeCommand}" CommandParameter="Strength" />
        </Grid>
        <Grid ColumnDefinitions="*, Auto, Auto">
            <Label Grid.Column="0" Text="{Binding Character.Dexterity, StringFormat='Dexterity: {0}'}" />
            <Button Grid.Column="1" Text="+" Command="{Binding UpgradeAttributeCommand}" CommandParameter="Dexterity" />
        </Grid>
        <Grid ColumnDefinitions="*, Auto, Auto">
            <Label Grid.Column="0" Text="{Binding Character.Constitution, StringFormat='Constitution: {0}'}" />
            <Button Grid.Column="1" Text="+" Command="{Binding UpgradeAttributeCommand}" CommandParameter="Constitution" />
        </Grid>
        <Grid ColumnDefinitions="*, Auto, Auto">
            <Label Grid.Column="0" Text="{Binding Character.Intelligence, StringFormat='Intelligence: {0}'}" />
            <Button Grid.Column="1" Text="+" Command="{Binding UpgradeAttributeCommand}" CommandParameter="Intelligence" />
        </Grid>
        <Grid ColumnDefinitions="*, Auto, Auto">
            <Label Grid.Column="0" Text="{Binding Character.Wisdom, StringFormat='Wisdom: {0}'}" />
            <Button Grid.Column="1" Text="+" Command="{Binding UpgradeAttributeCommand}" CommandParameter="Wisdom" />
        </Grid>
        <Grid ColumnDefinitions="*, Auto, Auto">
            <Label Grid.Column="0" Text="{Binding Character.Charisma, StringFormat='Charisma: {0}'}" />
            <Button Grid.Column="1" Text="+" Command="{Binding UpgradeAttributeCommand}" CommandParameter="Charisma" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>
