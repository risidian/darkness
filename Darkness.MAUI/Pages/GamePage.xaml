<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             xmlns:controls="clr-namespace:Darkness.MAUI.Controls"
             x:Class="Darkness.MAUI.Pages.GamePage"
             x:DataType="vm:GamePageViewModel"
             Title="Darkness World"
             BackgroundColor="Black">


    <Grid>
        <!-- MonoGame layer (Windows) -->
        <controls:MonoGameHost Game="{Binding GameInstance}" HorizontalOptions="Fill" VerticalOptions="Fill"
                               IsVisible="{Binding IsEngineAvailable}" />

        <!-- Fallback world view (Android / unsupported platforms) -->
        <Grid IsVisible="{Binding IsEngineUnavailable}"
              BackgroundColor="#C2B280">
            <!-- Water (south) -->
            <BoxView Color="#006994" VerticalOptions="End" HeightRequest="120" />
            <!-- NPC -->
            <BoxView Color="Blue" WidthRequest="64" HeightRequest="64"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="400,200,0,0" />
            <!-- Player -->
            <BoxView Color="Red" WidthRequest="64" HeightRequest="64"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="200,300,0,0" />
            <!-- Label -->
            <Label Text="Shore of Camelot" TextColor="White" FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Start" Margin="0,20,0,0" />
            <Label Text="Move with on-screen controls (coming soon)" TextColor="White" FontSize="14"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- Top Menu Layer -->
        <HorizontalStackLayout VerticalOptions="Start" HorizontalOptions="Start" Padding="15" Spacing="10">
            <Button Text="Menu"
                    WidthRequest="80"
                    BackgroundColor="#BB86FC"
                    TextColor="Black"
                    FontAttributes="Bold"
                    Command="{Binding GoBackCommand}" />
        </HorizontalStackLayout>

        <!-- UI Overlay layer -->
        <VerticalStackLayout VerticalOptions="End" Padding="20" Spacing="10" InputTransparent="False">
            <Button Text="Open Combat (Test)"
                    BackgroundColor="#444"
                    TextColor="White"
                    Command="{Binding OpenCombatTestCommand}"
                    ZIndex="1" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
