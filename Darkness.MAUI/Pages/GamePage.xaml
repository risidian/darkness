<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             xmlns:controls="clr-namespace:Darkness.MAUI.Controls"
             x:Class="Darkness.MAUI.Pages.GamePage"
             x:DataType="vm:GamePageViewModel"
             Title="Darkness World"
             BackgroundColor="Black">

    <Grid>
        <!-- The MonoGameHost is the background layer -->
        <controls:MonoGameHost Game="{Binding GameInstance}" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <!-- UI Overlay layer - defined after to be on top -->
        <VerticalStackLayout VerticalOptions="End" Padding="20" Spacing="10" InputTransparent="False">
            <Button Text="Open Combat (Test)"
                    BackgroundColor="#444"
                    TextColor="White"
                    Command="{Binding OpenCombatTestCommand}"
                    ZIndex="1" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
