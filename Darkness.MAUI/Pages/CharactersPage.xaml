<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             x:Class="Darkness.MAUI.Pages.CharactersPage"
             x:DataType="vm:CharactersViewModel"
             Title="Characters">
    <Grid RowDefinitions="*, 2*" ColumnDefinitions="*">
        <ListView Grid.Row="0" ItemsSource="{Binding Characters}" SelectedItem="{Binding SelectedCharacter}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Name}" Detail="{Binding Class}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="10">
            <Label Text="{Binding SelectedCharacter.Name}" FontSize="Large" />
            <Label Text="{Binding SelectedCharacter.Class}" />
            <Label Text="{Binding SelectedCharacter.Level, StringFormat='Level: {0}'}" />
            <Label Text="{Binding SelectedCharacter.Experience, StringFormat='XP: {0}'}" />
            <Button Text="Study" Command="{Binding GoToStudyCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
