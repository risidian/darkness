<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darkness.Core.ViewModels;assembly=Darkness.Core"
             xmlns:models="clr-namespace:Darkness.Core.Models;assembly=Darkness.Core"
             xmlns:converters="clr-namespace:Darkness.MAUI.Converters"
             x:Class="Darkness.MAUI.Pages.AlliesPage"
             x:DataType="vm:AlliesViewModel"
             Title="Allies">
    <ContentPage.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
    </ContentPage.Resources>
    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshAlliesCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="10" Spacing="20">
                <Label Text="Pending Requests" FontSize="20" FontAttributes="Bold" />
                <CollectionView ItemsSource="{Binding PendingRequests}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Ally">
                            <Frame Margin="0,5" Padding="10" BorderColor="Gray">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding AllyUsername}" FontSize="18" FontAttributes="Bold" />
                                        <Label Text="{Binding Status}" FontSize="14" TextColor="Gray" />
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                        <Button Text="Accept" 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AlliesViewModel}}, Path=AcceptRequestCommand}" 
                                                CommandParameter="{Binding .}" 
                                                BackgroundColor="Green" />
                                        <Button Text="Decline" 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AlliesViewModel}}, Path=DeclineRequestCommand}" 
                                                CommandParameter="{Binding .}" 
                                                BackgroundColor="Red" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="My Allies" FontSize="20" FontAttributes="Bold" />
                <CollectionView ItemsSource="{Binding AcceptedAllies}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Ally">
                            <Frame Margin="0,5" Padding="10" BorderColor="Gray">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding AllyUsername}" FontSize="18" FontAttributes="Bold" />
                                        <Label Text="{Binding Status}" FontSize="14" TextColor="Gray" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
